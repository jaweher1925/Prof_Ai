// SQLite for local development — no Azure DB needed.
// When you're ready to deploy, change provider to "postgresql"
// and update DATABASE_URL to your Azure PostgreSQL connection string.

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id              String       @id @default(uuid())
  title           String
  status          String       @default("draft")
  hiltGates       String?      @map("hilt_gates")   // JSON string in SQLite
  defaultAvatarId String?      @map("default_avatar_id")
  defaultVoiceId  String?      @map("default_voice_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  modules         Module[]
  scripts         Script[]
  sourceFiles     SourceFile[]

  @@map("projects")
}

model Module {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title      String
  objective  String?
  orderIndex Int      @map("order_index")
  status     String   @default("proposed")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  scenes     Scene[]
  scripts    Script[]

  @@map("modules")
}

model Scene {
  id                String    @id @default(uuid())
  moduleId          String    @map("module_id")
  module            Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  orderIndex        Int       @map("order_index")
  scriptContent     String?   @map("script_content")
  slideDeckContent  String?   @map("slide_deck_content")  // JSON string
  visualPrompt      String?   @map("visual_prompt")
  visualAssetUrl    String?   @map("visual_asset_url")
  textAnimationType String    @default("none") @map("text_animation_type")
  textCues          String?   @map("text_cues")            // JSON string
  presenterPosition String    @default("bottom-right") @map("presenter_position")
  avatarPositionX   Float?    @map("avatar_position_x")
  avatarPositionY   Float?    @map("avatar_position_y")
  ttsAudioUrl       String?   @map("tts_audio_url")
  avatarVideoUrl    String?   @map("avatar_video_url")
  status            String    @default("draft")
  durationSeconds   Float?    @map("duration_seconds")
  approvedAt        DateTime? @map("approved_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("scenes")
}

model Script {
  id                       String   @id @default(uuid())
  projectId                String   @map("project_id")
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId                 String?  @map("module_id")
  module                   Module?  @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  title                    String
  version                  Int      @default(1)
  learningObjectives       String   @default("[]") @map("learning_objectives") // JSON string
  sections                 String   @default("[]")                             // JSON string
  status                   String   @default("review")
  estimatedDurationMinutes Float    @default(4.0) @map("estimated_duration_minutes")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@map("scripts")
}

model SourceFile {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileName  String   @map("file_name")
  fileType  String   @map("file_type")
  fileUrl   String   @map("file_url")
  fileSize  Int?     @map("file_size")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("source_files")
}
